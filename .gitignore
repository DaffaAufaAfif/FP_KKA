# .gitignore for a Python project
# Generated to exclude bytecode, virtualenvs, build artifacts, and editor files

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
*.egg-info/
*.egg
pip-wheel-metadata/
wheels/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage
.tox/
.nox/
.coverage
.coverage.*
.cache
coverage.xml
*,cover
.hypothesis/
.pytest_cache/
htmlcov/

# Virtual environments
venv/
ENV/
env/
.venv/
venv.bak/

# Env files
.env
.env.*

# Jupyter
.ipynb_checkpoints

# PyInstaller
*.manifest
*.spec

# Pyre type checker
.pyre/

# IDEs and editors
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# macOS
.DS_Store

# Logs and databases
*.log
*.sql
*.sqlite3

# Mypy / caches
.mypy_cache/

# Generated files
__pycache__/
*.pyc
*.pyo
*.pyd

# Wheels
*.whl

# Backup files
*~
*.bak
